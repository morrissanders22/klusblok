# --- Database ---
# Local: postgresql://klusblok:klusblok@localhost:5432/klusblok?schema=public
# Vercel deploy: paste Neon/Vercel Postgres connection string here
DATABASE_URL="postgresql://klusblok:klusblok@localhost:5432/klusblok?schema=public"

# --- Auth.js ---
# Genereer met: openssl rand -base64 32
AUTH_SECRET="change-me"
# Local: http://localhost:3002 — Production: https://<your-domain>
NEXTAUTH_URL="http://localhost:3002"

# --- App ---
# Used in verify-mail links + Mollie redirect URLs
APP_URL="http://localhost:3002"

# --- Mollie ---
# Leeg laten in dev → betalingen worden automatisch geslaagd via /payments/[id]/dev-confirm
# Production: vul je test_xxx of live_xxx key in
# MOLLIE_API_KEY="test_xxxxxxxxxxxxxxxxxx"

# --- Vercel Blob (foto-uploads in productie) ---
# Local: leeg laten → uploads gaan naar public/uploads/
# Vercel: koppel een Blob store via Project → Storage, dan wordt deze automatisch geïnjecteerd
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxxxxxx"
